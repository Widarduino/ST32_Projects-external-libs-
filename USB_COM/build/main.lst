 123:Core/Src/main.c **** void USB_RXCallback(uint8_t*Buf,uint32_t *Len){
 124:Core/Src/main.c ****   memset(usbRxBuff,0,sizeof(usbRxBuff)); // reset buffer
 125:Core/Src/main.c ****   memcpy(usbRxBuff,Buf,*Len); // cpy buf to Rx buffer 
 126:Core/Src/main.c ****   
 127:Core/Src/main.c ****   usbRXBufLen = *Len; // set length
 128:Core/Src/main.c ****   usbRXFlag =1; // set flag
 129:Core/Src/main.c **** }
 130:Core/Src/main.c **** /* USER CODE END 0 */
