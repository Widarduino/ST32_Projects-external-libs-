 121:Core/Src/main.c ****   memset(usbRxBuff,0,sizeof(usbRxBuff)); // reset buffer
 122:Core/Src/main.c ****   memcpy(usbRxBuff,Buf,*Len); // cpy buf to Rx buffer 
 123:Core/Src/main.c ****   
 124:Core/Src/main.c ****   usbRXBufLen = *Len; // set length
 125:Core/Src/main.c ****   usbRXFlag =1; // set flag
 126:Core/Src/main.c **** }
