 210:USB_DEVICE/App/usbd_cdc_if.c ****   /* Line Coding Structure                                                       */
 211:USB_DEVICE/App/usbd_cdc_if.c ****   /*-----------------------------------------------------------------------------*/
 212:USB_DEVICE/App/usbd_cdc_if.c ****   /* Offset | Field       | Size | Value  | Description                          */
 213:USB_DEVICE/App/usbd_cdc_if.c ****   /* 0      | dwDTERate   |   4  | Number |Data terminal rate, in bits per second*/
 214:USB_DEVICE/App/usbd_cdc_if.c ****   /* 4      | bCharFormat |   1  | Number | Stop bits                            */
 215:USB_DEVICE/App/usbd_cdc_if.c ****   /*                                        0 - 1 Stop bit                       */
 216:USB_DEVICE/App/usbd_cdc_if.c ****   /*                                        1 - 1.5 Stop bits                    */
 217:USB_DEVICE/App/usbd_cdc_if.c ****   /*                                        2 - 2 Stop bits                      */
 218:USB_DEVICE/App/usbd_cdc_if.c ****   /* 5      | bParityType |  1   | Number | Parity                               */
 219:USB_DEVICE/App/usbd_cdc_if.c ****   /*                                        0 - None                             */
 220:USB_DEVICE/App/usbd_cdc_if.c ****   /*                                        1 - Odd                              */
 221:USB_DEVICE/App/usbd_cdc_if.c ****   /*                                        2 - Even                             */
 222:USB_DEVICE/App/usbd_cdc_if.c ****   /*                                        3 - Mark                             */
 223:USB_DEVICE/App/usbd_cdc_if.c ****   /*                                        4 - Space                            */
 224:USB_DEVICE/App/usbd_cdc_if.c ****   /* 6      | bDataBits  |   1   | Number Data bits (5, 6, 7, 8 or 16).          */
 225:USB_DEVICE/App/usbd_cdc_if.c ****   /*******************************************************************************/
 226:USB_DEVICE/App/usbd_cdc_if.c ****     case CDC_SET_LINE_CODING:
 227:USB_DEVICE/App/usbd_cdc_if.c ****       LineCoding.bitrate = (uint32_t)(pbuf[0] | pbuf[1] << 8 | pbuf[2] << 16 | pbuf[3] << 24);
